# ==============================================
# Bird Project - Environment Variables Template
# ==============================================
# このファイルを .env にコピーして使用してください
# 本番環境では AWS Systems Manager Parameter Store を使用

# ----------------------------------------------
# Application
# ----------------------------------------------
APP_NAME=bird
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# ----------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=bird
DB_USERNAME=bird_user
DB_PASSWORD=bird_pass

# ----------------------------------------------
# Security - JWT
# ----------------------------------------------
# 本番環境では必ず変更してください（32文字以上のランダム文字列）
JWT_SECRET=your-jwt-secret-key-change-in-production-min-32-chars
JWT_TTL=3600
JWT_REFRESH_TTL=20160

# ----------------------------------------------
# External API - Reinfolib (国土交通省 不動産情報ライブラリ)
# ----------------------------------------------
# ⚠️ このキーは外部に漏洩しないよう厳重に管理してください
REINFOLIB_API_KEY=b7ea735e49bb4de8b72ed04efe0a4de1
REINFOLIB_API_BASE_URL=https://www.reinfolib.mlit.go.jp/ex-api/external

# ----------------------------------------------
# Redis (Queue & Cache)
# ----------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# ----------------------------------------------
# Queue
# ----------------------------------------------
QUEUE_CONNECTION=redis
QUEUE_DRIVER=redis

# ----------------------------------------------
# Cache
# ----------------------------------------------
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# ----------------------------------------------
# Logging
# ----------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ----------------------------------------------
# Frontend (Next.js)
# ----------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_MAP_INITIAL_ZOOM=9
NEXT_PUBLIC_MAP_INITIAL_CENTER_LAT=35.6812
NEXT_PUBLIC_MAP_INITIAL_CENTER_LNG=139.7671

# ----------------------------------------------
# Development Tools
# ----------------------------------------------
TELESCOPE_ENABLED=true
TELESCOPE_DRIVER=database

# ----------------------------------------------
# AWS (本番環境用)
# ----------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-northeast-1
# AWS_BUCKET=
# AWS_RDS_ENDPOINT=
# AWS_ELASTICACHE_ENDPOINT=

# ----------------------------------------------
# Monitoring & Logging (本番環境用)
# ----------------------------------------------
# SENTRY_LARAVEL_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
